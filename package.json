{
  "name": "flex-rest",
  "version": "1.1.3",
  "description": "Bridge between Axios, CodeceptJS, and Playwright REST APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kobenguyent/flex-rest.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.4"
  },
  "files": [
    "dist/*",
    "tsconfig.json",
    "README.md"
  ],
  "author": "kobenguyent",
  "keywords": [
    "rest",
    "api",
    "axios",
    "codeceptjs",
    "playwright",
    "supertest",
    "testing",
    "typescript"
  ]
}
